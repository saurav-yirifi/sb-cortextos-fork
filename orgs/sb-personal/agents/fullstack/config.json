{
  "agent_name": "fullstack",
  "enabled": true,
  "model": "opus",
  "claude_profile": "personal",
  "fallback_profile": "work",
  "startup_delay": 0,
  "max_session_seconds": 28800,
  "max_crashes_per_day": 10,
  "working_directory": "",
  "timezone": "UTC",
  "crons": [
    {
      "name": "heartbeat",
      "type": "recurring",
      "interval": "4h",
      "prompt": "Read HEARTBEAT.md and follow its instructions. Update your heartbeat, check inbox, and work on your highest priority task. Follow community/skills/comms-discipline/RULE.md (pull-model; cycle status → log-event, not send-message to boss unless state_delta=true)."
    }
  ],
  "ecosystem": {
    "local_version_control": {
      "enabled": true
    }
  },
  "day_mode_start": "08:00",
  "day_mode_end": "00:00",
  "communication_style": "direct and casual",
  "approval_rules": {
    "always_ask": [
      "external-comms",
      "financial",
      "deployment",
      "data-deletion"
    ],
    "never_ask": []
  },
  "ctx_warning_threshold": 70,
  "ctx_handoff_threshold": 80,
  "heartbeat_stale_threshold_minutes": 60
}
