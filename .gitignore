node_modules/
# Ignore contents of .claude/ by default, then selectively re-include the dirs
# that are part of the framework. The trailing `**` (not bare `.claude/`) is
# load-bearing — `.claude/` would prevent git from descending and the negations
# below would be dead. With `.claude/**`, the dir itself stays trackable and
# per-subdir / per-file negations work.
.claude/**
!.claude/commands/
!.claude/commands/**
!.claude/orchestration-cortextos-node/
!.claude/rules/
!.claude/rules/**
!.claude/skills/
!.claude/skills/**
# Include template .claude dirs (needed for agent settings.json)
!templates/**/.claude/
!templates/**/.claude/**
dist/
ecosystem.config.js

# User-created org data (not part of the framework)
# Default: ignore everything under orgs/, but explicitly track non-secret agent config so
# changes to model / thresholds / MCP allowlist / identity prose are diff-able. .env stays
# ignored via the global .env rule below.
orgs/**
!orgs/
!orgs/*/
!orgs/*/agents/
!orgs/*/agents/*/
!orgs/*/agents/*/config.json
!orgs/*/agents/*/CLAUDE.md
!orgs/*/agents/*/IDENTITY.md
!orgs/*/agents/*/SOUL.md
!orgs/*/agents/*/GOALS.md
!orgs/*/agents/*/GUARDRAILS.md
!orgs/*/agents/*/HEARTBEAT.md
!orgs/*/agents/*/.mcp.json
!orgs/*/agents/*/.claude/
!orgs/*/agents/*/.claude/settings.json
# But community subdirectories ARE part of the framework
!community/
!community/**

# Secrets
.env
!.env.example
templates/*/.env
.cortextos-env

# Agent runtime data
orgs/*/agents/*/memory/
agents/*/local/
agents/*/telegram-images/

# Local instance state (per-operator runtime spillover; never canonical)
.cortextOS/
agents/*/memory/

# macOS metadata
.DS_Store

# Test artifacts
test-results/
*.log
# Spurious directory created when ${APPDATA} env var unexpanded during npm link on Windows
${APPDATA}/

# Knowledge base
knowledge-base/venv/
knowledge-base/__pycache__/
knowledge-base/scripts/__pycache__/
knowledge-base/scripts/_test_clients/__pycache__/
tests/playwright/dashboard-ui.spec.ts

# Local ops docs (personal, not for public repo)
docs/

# Internal developer/planning notes (not for public repo)
KNOWN-ISSUES.md
WINDOWS-IMPLEMENTATION-PLAN.md
WINDOWS-SUPPORT-INVESTIGATION.md
BRAINDUMP*.md
AGENTS.md
dashboard/screenshots/
dashboard/test-*.py
